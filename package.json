{
  "name": "@cablate/memory-lancedb-mcp",
  "version": "2.0.13",
  "mcpName": "io.github.cablate/memory-lancedb",
  "description": "MCP server for LanceDB-backed long-term memory with hybrid retrieval (Vector + BM25), cross-encoder rerank, multi-scope isolation, and memory lifecycle management",
  "type": "module",
  "main": "server.ts",
  "bin": {
    "memory-lancedb-mcp": "./bin/memory-lancedb-mcp.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "memory",
    "lancedb",
    "vector-search",
    "bm25",
    "hybrid-retrieval",
    "rerank",
    "ai-memory",
    "long-term-memory"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cablate/memory-lancedb-mcp.git"
  },
  "homepage": "https://github.com/cablate/memory-lancedb-mcp#readme",
  "bugs": {
    "url": "https://github.com/cablate/memory-lancedb-mcp/issues"
  },
  "author": "CabLate",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sinclair/typebox": "0.34.48",
    "apache-arrow": "18.1.0",
    "openai": "^6.21.0",
    "jiti": "^2.6.0"
  },
  "scripts": {
    "start": "npx tsx server.ts",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "commander": "^14.0.0",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "tsx": "^4.19.0"
  },
  "peerDependenciesMeta": {
    "tsx": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.27.4"
  }
}
