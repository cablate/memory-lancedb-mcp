# Embedding provider (required)
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# LanceDB storage path (optional)
# MEMORY_DB_PATH=./memory-data

# Full config file path (optional, overrides individual env vars)
# MEMORY_LANCEDB_CONFIG=/path/to/config.json
